# Environment variables for Docker Compose
# Copy this file to .env and update with your values
# DO NOT commit .env file to version control!

# Application Configuration
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=info

# Database Configuration
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=appdb
DATABASE_URL=postgresql://user:password@postgres:5432/appdb

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# API Configuration (if needed)
API_KEY=your-api-key-here
SECRET_KEY=your-secret-key-here

# Ports (optional overrides)
WEB_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ------------------------------------------------------------------------------
# Shared stack: intranet + Sentry + pgwatch postgres / pgbouncer + compose.redis.yml
# ------------------------------------------------------------------------------
# Create once:  docker network create intranet
#
# Merge example:
#   docker compose -f docker-compose.yml -f docker-compose-sentry.yml up -d
# (or `-f sentry/docker-compose.yml` from repo root; paths differ for build context.)
#
# PostgreSQL: only pgwatch/docker/compose.postgres.yml defines the `postgres` container.
# Copy pgwatch/docker/.env.merge.example -> pgwatch/docker/.env (compose loads it from that folder).
# Server uses POSTGRES_HOST_AUTH_METHOD=trust so services on `intranet` connect without passwords.
#
# PgBouncer: pgwatch/docker/compose.pgbouncer.yml (service `pgbouncer`, port 5432 inside Docker).
# Sentry Django uses HOST=pgbouncer (see sentry/sentry/sentry.conf.example.py). Pool mode: transaction.
# Host port mapping: PGBOUNCER_PORT=6432 (optional)
#
# Redis: compose.redis.yml — no password; hostname `redis`, port 6379. Snuba/Sentry use REDIS_HOST=redis.
#
# Sentry container healthchecks interpolate the variables below (set them or `docker compose config` may fail):
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=10
HEALTHCHECK_START_PERIOD=60s
HEALTHCHECK_FILE_INTERVAL=30s
HEALTHCHECK_FILE_TIMEOUT=10s
HEALTHCHECK_FILE_RETRIES=5
HEALTHCHECK_FILE_START_PERIOD=60s
#
# Sentry UI: host port for nginx (container port 80). Upstream default is 9000; use 9001 if Graylog
# or another stack already binds 9000 on the host. Must match root `.env` when using docker-compose.yml.
SENTRY_BIND=9001
#
# Sentry images (see upstream self-hosted .env for current defaults):
# SENTRY_IMAGE=ghcr.io/getsentry/sentry:nightly
# SNUBA_IMAGE=ghcr.io/getsentry/snuba:nightly
# RELAY_IMAGE=ghcr.io/getsentry/relay:nightly
# SYMBOLICATOR_IMAGE=ghcr.io/getsentry/symbolicator:nightly
# VROOM_IMAGE=ghcr.io/getsentry/vroom:nightly
# UPTIME_CHECKER_IMAGE=ghcr.io/getsentry/uptime-checker:nightly
# TASKBROKER_IMAGE=ghcr.io/getsentry/taskbroker:nightly
#
# Note: pgwatch Postgres image is PostgreSQL 18; upstream Sentry tests against PG 14 — verify upgrades.

# ------------------------------------------------------------------------------
# WordPress (docker-compose-wordpress.yml) — uses shared `postgres` on intranet (PG4WP image)
# ------------------------------------------------------------------------------
# WORDPRESS_HTTP_PORT=8088
# WORDPRESS_DB_NAME=wordpress
# WORDPRESS_DB_USER=postgres
# WORDPRESS_DB_PASSWORD=
# WORDPRESS_DB_SUPERUSER=postgres
# WORDPRESS_DB_SUPERUSER_PASSWORD=
# WORDPRESS_TABLE_PREFIX=wp_
